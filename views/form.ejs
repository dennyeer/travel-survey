<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Travel Persona Explorer</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-travel">

<nav class="navbar navbar-expand-lg navbar-dark" style="background: rgba(13,110,253,0.85);">
  <div class="container">
    <a class="navbar-brand" href="/">Travel Persona Explorer</a>
    <div class="navbar-nav ms-auto">
      <a class="nav-link" href="/pie">Pie Chart</a>
      <a class="nav-link" href="/bar">Bar Chart</a>
      <a class="nav-link" href="/map">Map View</a>
    </div>
  </div>
</nav>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-8">

      <div class="text-white mb-4">
        <h1 class="display-6 fw-semibold mb-2">Discover Your Travel Identity 🌍</h1>
        <p class="mb-0">Help us understand global travel trends in under 30 seconds.</p>
      </div>

      <div class="card glass-card shadow-lg">
        <div class="card-body p-4 p-md-5">
          <h2 class="h5 mb-4">Quick Survey</h2>

          <form method="POST" action="/submit">

            <div class="mb-3">
              <label class="form-label fw-semibold">What best describes your travel style?</label>
              <select name="travelStyle" class="form-select" required>
                <option value="">Select...</option>
                <option>Backpacking & Adventure</option>
                <option>Luxury & Comfort</option>
                <option>Solo Exploration</option>
                <option>Romantic Getaway</option>
                <option>Family Vacation</option>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">How often do you travel internationally?</label>
              <select name="travelFrequency" class="form-select" required>
                <option value="">Select...</option>
                <option>Once a year</option>
                <option>2–3 times per year</option>
                <option>More than 3 times per year</option>
                <option>Rarely</option>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Which continent is at the top of your travel bucket list?</label>
              <select name="dreamContinent" class="form-select" required>
                <option value="">Select...</option>
                <option>Europe</option>
                <option>Asia</option>
                <option>North America</option>
                <option>South America</option>
                <option>Africa</option>
                <option>Oceania</option>
              </select>
            </div>

            <div class="mb-4">
              <label class="form-label fw-semibold">What is your typical budget per international trip?</label>
              <select name="budgetRange" class="form-select" required>
                <option value="">Select...</option>
                <option>Under $1000</option>
                <option>$1000–$3000</option>
                <option>$3000–$5000</option>
                <option>Over $5000</option>
              </select>
            </div>

            <button class="btn btn-primary btn-wide w-100">Submit</button>
          </form>
        </div>
      </div>

    </div>
  </div>
</div>

</body>
</html>