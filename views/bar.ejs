<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Travel Frequency (Bar)</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <!-- amCharts v5 -->
  <script src="https://cdn.amcharts.com/lib/5/index.js"></script>
  <script src="https://cdn.amcharts.com/lib/5/xy.js"></script>
  <script src="https://cdn.amcharts.com/lib/5/themes/Animated.js"></script>

  <style>
    #chartdiv {
      width: 100%;
      height: 520px;
    }
  </style>
</head>

<body class="bg-light">
  <%- include('partials/navbar') %>

  <div class="container py-4">
    <a href="/success">← Back</a>

    <div class="card shadow-sm border-0 mt-3">
      <div class="card-body p-4">

        <div class="d-flex justify-content-between align-items-end">
          <div>
            <h1 class="h4 mb-1">Travel Frequency Overview</h1>
            <p class="text-muted mb-0">Hover (or tap on mobile) to see details.</p>
          </div>
          <a class="btn btn-outline-secondary" href="/">New Response</a>
        </div>

        <hr class="my-3">

        <div id="chartdiv"></div>

      </div>
    </div>
  </div>

  <!-- Safe JSON injection -->
  <script id="barDataJson" type="application/json">
    <%- JSON.stringify(barData || []) %>
  </script>

<script>
let barData = [];
try {
  barData = JSON.parse(document.getElementById("barDataJson").textContent || "[]");
  if (!Array.isArray(barData)) barData = [];
} catch (e) {
  barData = [];
}

// Ensure value is numeric
barData = barData.map(d => ({
  category: String(d.category),
  value: Number(d.value)
}));

// Short labels
function shortLabel(full) {
  if (full === "Rarely") return "Rarely";
  if (full === "Once a year") return "Once";
  if (full === "2–3 times per year" || full === "2-3 times per year") return "2-3";
  if (full === "More than 3 times per year") return "3+";
  return full;
}

am5.ready(function () {

  var root = am5.Root.new("chartdiv");
  root.setThemes([am5themes_Animated.new(root)]);
  if (root._logo) root._logo.dispose();

  var chart = root.container.children.push(
    am5xy.XYChart.new(root, {
      panX: false,
      panY: false,
      wheelX: "none",
      wheelY: "none"
    })
  );

  // X Axis
  var xRenderer = am5xy.AxisRendererX.new(root, {
    minGridDistance: 30
  });

  xRenderer.labels.template.adapters.add("text", function(text, target) {
    if (!target.dataItem) return text;
    return shortLabel(target.dataItem.get("category"));
  });

  var xAxis = chart.xAxes.push(
    am5xy.CategoryAxis.new(root, {
      categoryField: "category",
      renderer: xRenderer
    })
  );

  xAxis.data.setAll(barData);

  // Y Axis
  var yAxis = chart.yAxes.push(
    am5xy.ValueAxis.new(root, {
      renderer: am5xy.AxisRendererY.new(root, {})
    })
  );

  // Series
  var series = chart.series.push(
    am5xy.ColumnSeries.new(root, {
      xAxis: xAxis,
      yAxis: yAxis,
      valueYField: "value",
      categoryXField: "category"
    })
  );

  series.data.setAll(barData);

  // ✅ Tooltip MUST be bound to columns template
  series.columns.template.setAll({
    interactive: true,
    cornerRadiusTL: 8,
    cornerRadiusTR: 8,
    tooltipText: "{categoryX}: {valueY} responses"
  });

  // Hover feedback
  series.columns.template.states.create("hover", {
    opacity: 0.85
  });

  // Mobile tap support
  series.columns.template.events.on("pointerdown", function(ev) {
    ev.target.showTooltip();
  });

  series.appear(800);
  chart.appear(800,100);

});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>